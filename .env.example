# Copy this file to .env and fill in the values.
# Never commit the real .env file.

# --- Supabase ---
# From Supabase: Project Settings -> API (or Data API).
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# --- Auth ---
# Site URL used for OAuth redirects. Local dev: http://localhost:5173
# Production: https://<your-vercel-deployment>.vercel.app
VITE_SITE_URL=http://localhost:5173

# --- Anthropic API (server only) ---
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxx

# --- ClickSend (SMS send via /api/send-touchpoint) ---
# Get from: https://dashboard.clicksend.com -> API Credentials
# AU alphanumeric sender ID max 11 chars (replies don't route — use a number if you need replies).
CLICKSEND_USERNAME=your_clicksend_username
CLICKSEND_API_KEY=your_clicksend_api_key
SMS_SENDER_NAME=Murray

# --- Resend (NOT IN USE; email sends are copy-paste for now) -----------------
# Uncomment if you ever want to enable email send via the app.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# SENDER_EMAIL=onboarding@resend.dev
# SENDER_NAME=Murray
# REPLY_TO_EMAIL=murray@blacpropertygroup.com.au
