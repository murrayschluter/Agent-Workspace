# Copy this file to .env and fill in the values.
# Never commit the real .env file.

# --- Supabase ---
# From Supabase: Project Settings -> API (or Data API).
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# --- Auth ---
# Site URL used for OAuth redirects. Local dev: http://localhost:5173
# Production: https://<your-vercel-deployment>.vercel.app
VITE_SITE_URL=http://localhost:5173

# --- Anthropic API (server only) ---
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxx

# --- ClickSend (SMS send via /api/send-touchpoint) ---
# Get from: https://dashboard.clicksend.com -> API Credentials
# AU alphanumeric sender ID max 11 chars (replies don't route — use a number if you need replies).
CLICKSEND_USERNAME=your_clicksend_username
CLICKSEND_API_KEY=your_clicksend_api_key
SMS_SENDER_NAME=Murray

# --- Resend (NOT IN USE; email sends are copy-paste for now) -----------------
# Uncomment if you ever want to enable email send via the app.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# SENDER_EMAIL=onboarding@resend.dev
# SENDER_NAME=Murray
# REPLY_TO_EMAIL=murray@blacpropertygroup.com.au

# --- VaultRE sync (server only, used by /api/sync-vault-listings) ------------
# Both headers are required on every Vault call (verified in V0 spike — single-
# header requests 401). Live values live in
# ~/.openclaw/workspace/config/vault_fetcher.json on Antony's Mac; for Vercel
# they go in the dashboard env vars, never committed.
VAULTRE_API_KEY=replace_me_x_api_key_value
VAULTRE_BEARER_TOKEN=replace_me_authorization_bearer_value

# Shared secret the Vercel cron sends as `Authorization: Bearer <CRON_SECRET>`
# when invoking /api/sync-vault-listings. The function rejects calls without
# it (constant-time compare) so drive-by hits can't burn through Vault's rate
# limit. Generate with `openssl rand -hex 32`.
CRON_SECRET=replace_me_random_hex_string

# Supabase service-role key used ONLY by the sync function (server-side). It
# bypasses RLS so the function can write to vault_* tables after V4 enables
# RLS. NEVER expose to the client bundle. Get from Supabase: Project Settings
# -> API -> Service role (secret).
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxx
